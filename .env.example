SECRET_KEY=replace-with-long-random-secret
DEBUG=False
ALLOWED_HOSTS=api.connectlaundry.com
CORS_ALLOWED_ORIGINS=https://app.connectlaundry.com
CSRF_TRUSTED_ORIGINS=https://app.connectlaundry.com
DATABASE_URL=postgres://postgres:postgres@localhost:5432/connect_db
USE_POSTGIS=True
REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=django-db
DEFAULT_FROM_EMAIL=Connect Laundry <noreply@connectlaundry.com>
FRONTEND_URL=https://app.connectlaundry.com
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=mailer@example.com
EMAIL_HOST_PASSWORD=replace-with-mail-password
CLOUDINARY_CLOUD_NAME=cloud-name
CLOUDINARY_API_KEY=cloudinary-api-key
CLOUDINARY_API_SECRET=cloudinary-api-secret
PAYSTACK_SECRET_KEY=replace-with-paystack-secret
PAYSTACK_PUBLIC_KEY=replace-with-paystack-public
PAYSTACK_CALLBACK_URL=https://api.connectlaundry.com/api/v1/payments/callback/
PAYMENT_CURRENCY=GHS
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_TRACES_SAMPLE_RATE=0.05
DJANGO_LOG_LEVEL=INFO
INTERNAL_HEALTH_TOKEN=replace-with-health-token
